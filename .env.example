# Provider: anthropic | openai | google | groq | xai | openrouter ...
# OPENCLAW_MINI_PROVIDER=anthropic

# Model (需与 Provider 匹配)
# OPENCLAW_MINI_MODEL=claude-sonnet-4-20250514

# API Base URL (代理、自部署端点、Azure OpenAI 等)
# OPENCLAW_MINI_BASE_URL=https://your-proxy.example.com/v1

# API Key (也可用 Provider 对应的标准变量名)
# ANTHROPIC_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
# GROQ_API_KEY=xxx

# Agent ID
# OPENCLAW_MINI_AGENT_ID=main

# 飞书配置
FEISHU_ENABLED=true
FEISHU_APP_ID=xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxx

# 可选：加密密钥和验证令牌
# 在飞书开放平台的事件订阅中配置
# FEISHU_ENCRYPT_KEY=your-encrypt-key
# FEISHU_VERIFICATION_TOKEN=your-verification-token

# 测试用的会话ID（飞书用户ID或群聊ID）
# 格式：用户ID为 "u_" 开头，群聊ID为 "oc_" 开头
# FEISHU_TEST_CONVERSATION_ID=oc_xxxxxxxxxx


# 股票交易配置
STOCK_EASTMONEY_USERNAME=xxxxxxx
STOCK_EASTMONEY_PASSWORD=xxxxx
# 东财验证识别码利用 dddocr 库来实现，已经试过了所有的其它验证码，但是没有找到一个准确率超过它的，所以只能使用 dddocr 库来实现
STOCK_EASTMONEY_VERIFY_CODE_URL=xxxxxxx